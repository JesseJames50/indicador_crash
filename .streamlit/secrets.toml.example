# Copie este arquivo para .streamlit/secrets.toml e preencha os valores.
# NUNCA commite secrets.toml no git — ele já está no .gitignore.
#
# No Streamlit Community Cloud, configure pelo painel:
#   App → Settings → Secrets  (cole o conteúdo abaixo com os valores reais)

FRED_API_KEY = "sua_chave_aqui"
